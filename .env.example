# =============================================================================
# Connective Health Global - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All required variables must be set for the application to work.
# =============================================================================

# ── Supabase (Required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ogwjsqancmgysyqxwkov.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Site Configuration (Required) ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://connectivehealthglobal.com
NEXT_PUBLIC_SITE_NAME=Connective Health Global

# ── GoHighLevel Integration (Optional - for CRM sync) ─────────────────────────
# Used for newsletter subscriber sync and lead generation CRM.
# GHL_API_KEY=your_api_key_here
# GHL_LOCATION_ID=your_location_id_here

# ── GoHighLevel Webhooks (Optional - for incoming lead/call data) ─────────────
# GHL_WEBHOOK_SECRET=your_webhook_secret

# ── Next.js / Application ────────────────────────────────────────────────────
# NODE_ENV=production|development|test
# NEXT_TELEMETRY_DISABLED=1
